{
  "name": "ai-agent-desktop",
  "version": "0.2.0",
  "description": "Electron desktop shell for the local multi-agent coding copilot.",
  "author": "Eric",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:backend": "python3 -m app.server --reload --host 127.0.0.1 --port 8000",
    "dev:electron": "wait-on http://127.0.0.1:8000/health && cross-env ELECTRON_START_URL=http://127.0.0.1:8000 electron .",
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:electron\"",
    "start": "electron .",
    "build:backend": "pyinstaller --noconfirm --clean --name ai-agent-backend --onefile --add-data templates:templates --add-data static:static app/server.py",
    "build:desktop": "npm run build:backend && electron-builder --mac dmg"
  },
  "build": {
    "appId": "com.eric.aiagentdesktop",
    "productName": "AI Agent Desktop",
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "dist/ai-agent-backend",
        "to": "backend/ai-agent-backend"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "wait-on": "^8.0.1"
  }
}
